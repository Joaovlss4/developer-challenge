#!/usr/bin/env bash
#
# pre-push hook — Proteção de arquivos do repositório
#
# Bloqueia o push caso algum commit a ser enviado contenha modificações
# em arquivos protegidos do repositório do desafio.
#
# Arquivos/diretórios protegidos:
#   - AGENTS.md
#   - CLAUDE.md
#   - setup.sh
#   - .cursor/  (qualquer arquivo)
#   - .githooks/ (qualquer arquivo)
#   - .agents/  (qualquer arquivo exceto .agents/changelog/diff.md)
#

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

PROTECTED_PATTERNS=(
  "^AGENTS\.md$"
  "^CLAUDE\.md$"
  "^setup\.sh$"
  "^\.cursor/"
  "^\.githooks/"
)

# .agents/ é protegido exceto o changelog de IA
AGENTS_DIR_PATTERN="^\.agents/"
AGENTS_CHANGELOG_EXCEPTION="^\.agents/changelog/diff\.md$"

remote="$1"
url="$2"

z40="0000000000000000000000000000000000000000"

blocked_files=()

while read local_ref local_sha remote_ref remote_sha; do
  # Push de delete — sem commits para verificar
  if [ "$local_sha" = "$z40" ]; then
    continue
  fi

  # Determina o range de commits a verificar
  if [ "$remote_sha" = "$z40" ]; then
    # Branch nova: verifica todos os commits do push
    range="$local_sha"
    commit_list=$(git rev-list "$range")
  else
    range="$remote_sha..$local_sha"
    commit_list=$(git rev-list "$range")
  fi

  for commit in $commit_list; do
    # Lista os arquivos modificados neste commit
    changed_files=$(git diff-tree --no-commit-id -r --name-only "$commit" 2>/dev/null)

    while IFS= read -r file; do
      [ -z "$file" ] && continue

      # Verifica padrões protegidos diretos
      for pattern in "${PROTECTED_PATTERNS[@]}"; do
        if echo "$file" | grep -qE "$pattern"; then
          blocked_files+=("$file (commit: ${commit:0:8})")
          break
        fi
      done

      # Verifica .agents/ com exceção para diff.md
      if echo "$file" | grep -qE "$AGENTS_DIR_PATTERN"; then
        if ! echo "$file" | grep -qE "$AGENTS_CHANGELOG_EXCEPTION"; then
          blocked_files+=("$file (commit: ${commit:0:8})")
        fi
      fi

    done <<< "$changed_files"
  done
done

if [ ${#blocked_files[@]} -gt 0 ]; then
  echo ""
  echo -e "${RED}╔══════════════════════════════════════════════════════════════╗${NC}"
  echo -e "${RED}║           PUSH BLOQUEADO — ARQUIVO PROTEGIDO DETECTADO       ║${NC}"
  echo -e "${RED}╚══════════════════════════════════════════════════════════════╝${NC}"
  echo ""
  echo -e "${YELLOW}Este push contém modificações em arquivos protegidos do repositório.${NC}"
  echo ""
  echo "Arquivo(s) proibido(s) detectado(s):"
  for f in "${blocked_files[@]}"; do
    echo -e "  ${RED}✗${NC} $f"
  done
  echo ""
  echo "Leia a seção '⚠️ Regras do Repositório' no README.md."
  echo ""
  exit 1
fi

exit 0
